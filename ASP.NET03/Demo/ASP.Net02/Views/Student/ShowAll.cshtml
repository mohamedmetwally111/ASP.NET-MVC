@model List<Student>
@{
    ViewData["Title"] = "ShowAll";
}

<h1>ShowAll</h1>
<table class="table table-hover">

    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>Id</th>
        <th>DeprtmentId</th>

    </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Age</td>
            <td>@item.Id</td>
            <td>@item.DepartmentId</td>
        </tr>
    }

</table>

